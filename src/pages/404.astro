---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 Not Found — fixerror.dev" description="The page you're looking for doesn't exist." path="/404/" noindex>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
    <code class="font-mono text-7xl font-bold text-[color:var(--color-danger)] block mb-4">404</code>
    <h1 class="text-2xl font-bold mb-3">Not Found</h1>
    <p class="text-[color:var(--color-text-muted)] mb-8">
      The page you're looking for doesn't exist on fixerror.dev. Maybe one of these helps?
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a href="/" class="px-4 py-2 rounded-md bg-[color:var(--color-accent)] text-[color:var(--color-bg)] text-sm font-medium hover:bg-[color:var(--color-accent-hover)]">Home</a>
      <a href="/services/" class="px-4 py-2 rounded-md border border-[color:var(--color-border)] text-sm font-medium hover:border-[color:var(--color-accent)]">All services</a>
      <a href="/http/" class="px-4 py-2 rounded-md border border-[color:var(--color-border)] text-sm font-medium hover:border-[color:var(--color-accent)]">HTTP codes</a>
      <a href="/search" class="px-4 py-2 rounded-md border border-[color:var(--color-border)] text-sm font-medium hover:border-[color:var(--color-accent)]">Search</a>
    </div>
  </div>
</BaseLayout>
