---
interface Props {
  variant?: 'rail' | 'inline';
  context?: string;
}
const { variant = 'rail', context } = Astro.props;
const headline =
  context === 'rate-limit'
    ? 'Catch rate-limit spikes before users do'
    : context === 'auth'
    ? 'Get alerted on every auth failure'
    : context === 'database'
    ? 'Track DB errors in production'
    : 'Catch these errors before users do';
---
{variant === 'rail' ? (
  <aside class="not-prose hidden xl:block sticky top-20 self-start">
    <div class="rounded-lg border border-[color:var(--color-border-strong)] bg-[color:var(--color-bg-card)] p-5 w-72">
      <div class="text-xs font-mono uppercase tracking-wider text-[color:var(--color-text-dim)] mb-2">Sponsored</div>
      <h3 class="font-semibold text-[color:var(--color-text)] leading-tight mb-2">{headline}</h3>
      <p class="text-sm text-[color:var(--color-text-muted)] leading-relaxed mb-4">
        Sentry catches errors in production with full stack traces, user context, and release tracking. Free for solo devs.
      </p>
      <a
        href="https://sentry.io/signup/?utm_source=fixerror&utm_medium=affiliate"
        rel="sponsored noopener"
        target="_blank"
        class="inline-flex items-center gap-1.5 text-sm font-medium px-3 py-1.5 rounded-md bg-[color:var(--color-accent)] text-[color:var(--color-bg)] hover:bg-[color:var(--color-accent-hover)]"
      >
        Try Sentry free <span aria-hidden="true">→</span>
      </a>
      <p class="text-[10px] text-[color:var(--color-text-dim)] mt-3">Affiliate link — supports the site</p>
    </div>
  </aside>
) : (
  <aside class="not-prose my-6 rounded-md border border-[color:var(--color-border)] bg-[color:var(--color-bg-card)] p-4 flex items-center justify-between gap-4">
    <div>
      <div class="text-xs font-mono uppercase tracking-wider text-[color:var(--color-text-dim)] mb-1">Detection</div>
      <p class="text-sm text-[color:var(--color-text-muted)]">{headline} with Sentry — free for solo devs.</p>
    </div>
    <a
      href="https://sentry.io/signup/?utm_source=fixerror&utm_medium=affiliate"
      rel="sponsored noopener"
      target="_blank"
      class="flex-shrink-0 text-sm font-medium px-3 py-1.5 rounded-md border border-[color:var(--color-accent)]/40 text-[color:var(--color-accent)] hover:bg-[color:var(--color-accent)]/10"
    >
      Try free →
    </a>
  </aside>
)}
