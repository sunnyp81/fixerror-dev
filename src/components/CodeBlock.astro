---
import { codeToHtml } from 'shiki';

interface Props {
  code: string;
  language: string;
  filename?: string;
  caption?: string;
}
const { code, language, filename, caption } = Astro.props;

const html = await codeToHtml(code, {
  lang: language,
  themes: { light: 'github-light', dark: 'github-dark' },
  defaultColor: 'dark',
});
---
<figure class="my-5 rounded-lg overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-code-bg)]">
  {filename && (
    <div class="flex items-center justify-between px-4 py-2 border-b border-[color:var(--color-border)] bg-[color:var(--color-bg-elev)] text-xs font-mono text-[color:var(--color-text-muted)]">
      <span>{filename}</span>
      <span class="uppercase tracking-wider text-[color:var(--color-text-dim)]">{language}</span>
    </div>
  )}
  <div class="overflow-x-auto" set:html={html} />
  {caption && (
    <figcaption class="px-4 py-2 border-t border-[color:var(--color-border)] text-xs text-[color:var(--color-text-muted)]">
      {caption}
    </figcaption>
  )}
</figure>
