---
interface Props {
  cause: string;
  fix: string;
}
const { cause, fix } = Astro.props;
---
<aside class="not-prose my-6 rounded-lg border border-[color:var(--color-border-strong)] bg-[color:var(--color-bg-card)] p-5">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 w-10 h-10 rounded-md bg-[color:var(--color-accent)]/10 border border-[color:var(--color-accent)]/30 flex items-center justify-center font-mono text-xs font-semibold text-[color:var(--color-accent)]">
      TL;DR
    </div>
    <div class="flex-1 space-y-3 text-sm">
      <p><span class="font-semibold text-[color:var(--color-text)]">Cause:</span> <span class="text-[color:var(--color-text-muted)]">{cause}</span></p>
      <p><span class="font-semibold text-[color:var(--color-success)]">Fix:</span> <span class="text-[color:var(--color-text)]">{fix}</span></p>
    </div>
  </div>
</aside>
