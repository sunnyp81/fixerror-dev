---
interface Props {
  items: Array<{ q: string; a: string }>;
  heading?: string;
}
const { items, heading = 'Frequently asked questions' } = Astro.props;
---
<section class="mt-12">
  <h2 class="text-xl font-semibold tracking-tight mb-4">{heading}</h2>
  <div class="divide-y divide-[color:var(--color-border)] border-y border-[color:var(--color-border)]">
    {items.map((item) => (
      <details class="group py-4">
        <summary class="cursor-pointer flex items-start justify-between gap-4 list-none [&::-webkit-details-marker]:hidden">
          <span class="font-medium text-[color:var(--color-text)] group-open:text-[color:var(--color-accent)]">{item.q}</span>
          <span class="text-[color:var(--color-text-dim)] font-mono text-lg leading-none mt-0.5 group-open:rotate-45 transition-transform">+</span>
        </summary>
        <div class="mt-2 text-sm text-[color:var(--color-text-muted)] leading-relaxed">{item.a}</div>
      </details>
    ))}
  </div>
</section>
